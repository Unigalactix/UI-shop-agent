# ─────────────────────────────────────────────────────────────────────────────
# UI-Shop-Agent  ·  Environment Configuration Template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI credentials (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic credentials (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ── Walmart Credentials ───────────────────────────────────────────────────────
WALMART_EMAIL=your-email@example.com
WALMART_PASSWORD=your-password

# ── Browser Settings ─────────────────────────────────────────────────────────
# Set BROWSER_HEADLESS=true to run without a visible window (CI / server mode)
BROWSER_HEADLESS=false
# Slow-motion delay in milliseconds between Playwright actions (helps debugging)
BROWSER_SLOW_MO=300
# Global timeout in milliseconds for element waits / navigation
BROWSER_TIMEOUT=30000

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8765

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
